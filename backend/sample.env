# App
APP_NAME=askmeinsurance-backend
APP_ENV=local
APP_DEBUG=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auth
AUTH_ENABLED=true
JWT_ALGORITHM=RS256
JWT_AUDIENCE=
JWT_ISSUER=
JWT_PUBLIC_KEY=
AUTH_DEV_BEARER_TOKEN=dev-super-token-change-me

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# LLM Provider
LLM_PROVIDER=mock
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
OPENROUTER_API_KEY=

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
