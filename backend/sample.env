# App
APP_NAME=askmeinsurance-backend
APP_ENV=local
APP_DEBUG=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auth
AUTH_ENABLED=true
JWT_ALGORITHM=RS256
JWT_AUDIENCE=
JWT_ISSUER=
JWT_PUBLIC_KEY=

# Supabase
# Required for backend Supabase JWT verification when AUTH_ENABLED=true.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# LLM Provider
LLM_PROVIDER=mock
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
OPENROUTER_API_KEY=

# Retrieval tuning
# Minimum similarity score (0.0–1.0) for a chunk to be included in results.
# Set to 0.0 (default) to disable filtering. Recommended starting point: 0.5
TEXTBOOK_SCORE_THRESHOLD=0.0
PRODUCT_SUMMARY_SCORE_THRESHOLD=0.0

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
