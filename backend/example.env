# App
APP_NAME=askmeinsurance-backend
APP_ENV=local
APP_DEBUG=true

# Auth
AUTH_ENABLED=true
JWT_ALGORITHM=RS256
JWT_AUDIENCE=
JWT_ISSUER=
JWT_PUBLIC_KEY=


# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# LLM Provider
LLM_PROVIDER=gemini
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Langfuse
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=

# Dev superuser fallback auth (used by POST /api/v1/auth/dev-login)
# Must be enabled only in local/dev.
# Required when DEV_AUTH_ENABLED=true:
# - DEV_SUPERUSER_EMAIL
# - DEV_SUPERUSER_PASSWORD
# - DEV_JWT_SIGNING_SECRET
DEV_AUTH_ENABLED=true
DEV_SUPERUSER_EMAIL=dev-super-user@example.com
DEV_SUPERUSER_PASSWORD=change-me
DEV_JWT_SIGNING_SECRET=change-me-dev-jwt-secret
DEV_JWT_EXPIRES_MINUTES=60

# LangGraph retrieval (required for insurance/financial subgraph retrieval tools)
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=1536
QDRANT_URL=
QDRANT_API_KEY=
TEXTBOOK_TOP_K=5
PRODUCT_SUMMARY_TOP_K=5