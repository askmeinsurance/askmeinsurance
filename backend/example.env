# App
APP_NAME=askmeinsurance-backend
APP_ENV=local
APP_DEBUG=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auth
AUTH_ENABLED=true
JWT_ALGORITHM=RS256
JWT_AUDIENCE=
JWT_ISSUER=
JWT_PUBLIC_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# LLM providers
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OPENROUTER_API_KEY=

# Vector store
QDRANT_URL=
QDRANT_API_KEY=

# Embeddings
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=1536

# Retrieval tuning
TEXTBOOK_TOP_K=5
PRODUCT_SUMMARY_TOP_K=5
TEXTBOOK_SCORE_THRESHOLD=0.0
PRODUCT_SUMMARY_SCORE_THRESHOLD=0.0

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
LANGGRAPH_LOG_LEVEL=INFO
LANGGRAPH_LOG_STATE_EXCERPT_CHARS=240
LANGGRAPH_LOG_INCLUDE_PAYLOADS=false

# Guardrails (deepteam) — evaluation model configured in app/agent/config.yaml under "guardrails"
GUARDRAILS_ENABLED=false
GUARDRAILS_SAMPLE_RATE=1.0
