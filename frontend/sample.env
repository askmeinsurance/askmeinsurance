# Backend origin/base URL (Vite)
# Examples:
# - Local backend: http://localhost:8000
# - Deployed backend: https://api.example.com
# If empty, frontend falls back to same-origin relative path `/api/v1`.
VITE_BACKEND_BASE_URL=http://localhost:8000

# Supabase auth (optional in local dev when VITE_ENABLE_DEV_AUTH=true)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Enables backend /api/v1/auth/dev-login fallback when Supabase is unavailable
VITE_ENABLE_DEV_AUTH=false
